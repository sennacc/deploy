{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAgentWorkGeneral",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "ec2:StartInstances",
        "ec2:StopInstances",
        "s3:*",
        "rds:Describe*",
        "elasticache:Describe*",
        "cloudwatch:*",
        "logs:*",
        "ses:SendEmail",
        "ses:SendRawEmail",
        "sns:Publish",
        "ecr:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenySennaInfraEC2",
      "Effect": "Deny",
      "Action": [
        "ec2:TerminateInstances",
        "ec2:StopInstances",
        "ec2:ModifyInstanceAttribute",
        "ec2:DeleteSecurityGroup",
        "ec2:RevokeSecurityGroupIngress"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-1:432162758172:instance/i-096966078dc3a8767",
        "arn:aws:ec2:us-east-1:432162758172:instance/i-0ee3138f37b51bde0"
      ],
      "Condition": {}
    },
    {
      "Sid": "DenySennaInfraS3",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteBucket",
        "s3:DeleteObject",
        "s3:PutBucketPolicy"
      ],
      "Resource": [
        "arn:aws:s3:::sennacc-cloudtrail-logs",
        "arn:aws:s3:::sennacc-cloudtrail-logs/*",
        "arn:aws:s3:::sennacc-artifacts",
        "arn:aws:s3:::sennacc-artifacts/*"
      ]
    },
    {
      "Sid": "DenySennaInfraIAM",
      "Effect": "Deny",
      "Action": [
        "iam:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenySennaInfraCloudTrail",
      "Effect": "Deny",
      "Action": [
        "cloudtrail:DeleteTrail",
        "cloudtrail:StopLogging",
        "cloudtrail:UpdateTrail"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenySennaInfraGuardDuty",
      "Effect": "Deny",
      "Action": [
        "guardduty:DeleteDetector",
        "guardduty:DisassociateFromMasterAccount"
      ],
      "Resource": "*"
    }
  ]
}
